echo hello
echo hello | cat
echo hello | cat | cat
echo hello world | grep hello | cat
echo hello world | grep world | cat
echo a b c | grep a | grep a
echo one two three | grep two | wc -w
echo foo bar baz | grep -o foo | cat
echo hello world | grep hello | grep hello | cat
echo line one
echo line one | cat
echo line one | cat | cat | cat
echo aaa bbb | grep aaa | grep aaa | cat
echo test | grep test | grep test | grep test
echo alpha beta | grep alpha | cat | cat
echo hello | wc -c | cat
