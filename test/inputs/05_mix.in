echo abc def | grep def | grep def | grep def
ls / | grep bin
ls / | grep tmp
ls /etc | grep passwd
ls /etc | grep shells
cat /etc/shells | grep bin
cat /etc/shells | wc -l
cat /etc/shells | sort | head -3
cat /etc/passwd | grep root | head -1
cat /etc/passwd | wc -l
cat /etc/passwd | grep -c root
grep root /etc/passwd | cut -d: -f1
grep root /etc/passwd | wc -l
quit